# Base de données PostgreSQL
DATABASE_URL="postgresql://supptic:supptic_secret@localhost:5432/supptic_db"

# Serveur
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET="change_this_to_a_long_random_secret_in_production"
JWT_EXPIRES_IN="7d"

# Upload fichiers
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=5

# PDF
PDF_OUTPUT_DIR="./pdfs"
